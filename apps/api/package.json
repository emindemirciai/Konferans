{
  "name": "@lets-meet/api",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test:types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lets-meet/shared": "workspace:*",
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.9.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.10.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
