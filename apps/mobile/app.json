{
  "expo": {
    "name": "Konferans",
    "slug": "konferans",
    "scheme": "konferans",
    "version": "0.4.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.konferans.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Konferans kamera ile görüntülü görüşme için kameraya erişir.",
        "NSMicrophoneUsageDescription": "Konferans sesli görüşme için mikrofona erişir."
      }
    },
    "android": {
      "package": "com.konferans.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "@livekit/react-native",
        {}
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:4000",
      "googleClientId": "replace-with-mobile-client-id"
    }
  }
}
