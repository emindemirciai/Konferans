# Global
NODE_ENV=development
APP_NAME=Lets Meet
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880

# API
API_PORT=4000
JWT_SECRET=change-this-super-long-secret
JWT_EXPIRES_IN=7d
INVITE_ONLY=true
ALLOW_PUBLIC_REGISTRATION=false
CORS_ORIGIN=http://localhost:3000

# Database
POSTGRES_USER=letsmeet
POSTGRES_PASSWORD=letsmeet_password
POSTGRES_DB=letsmeet
DATABASE_URL=postgresql://letsmeet:letsmeet_password@postgres:5432/letsmeet?schema=public

# Redis
REDIS_URL=redis://redis:6379

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WS_URL=ws://livekit:7880
LIVEKIT_PUBLIC_WS_URL=ws://localhost:7880
LIVEKIT_DOMAIN=localhost
LIVEKIT_RTC_UDP_START=50000
LIVEKIT_RTC_UDP_END=50100

# Google OAuth / Google Identity Services
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com

# SMTP for email verification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace@example.com
SMTP_PASS=replace-password
SMTP_FROM="Lets Meet <noreply@example.com>"

# Seed
SEED_ADMIN_EMAIL=admin@letsmeet.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Lets Meet Admin


# Production hardening
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
TRUST_PROXY=true
MAX_JSON_BODY=2mb
ENABLE_SYSTEM_STATUS=true
BACKUP_DIR=/backups

# Push / notification future-provider keys
WEB_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_PRIVATE_KEY=replace-with-vapid-private-key
EXPO_PROJECT_ID=replace-with-expo-project-id
FCM_SERVER_KEY=replace-with-fcm-key
APNS_KEY_ID=replace-with-apns-key-id

# Website integration / SSO
WEBSITE_INTEGRATION_ALLOWED_ORIGINS=http://localhost:3000
SSO_TOKEN_TTL_SECONDS=120
